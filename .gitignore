# Dependencies
node_modules/

# Environment variables — never commit secrets
.env
.env.*
!.env.example

# data/ is runtime + generated content (live tokens, user data, locks, reports, caches).
# Allowlist model: ignore the whole dir, then `!`-exempt anything that must be tracked.
# Nothing is tracked today — add `!data/<file>` here if that ever changes.
# This kills the stale-lock / stray-output whack-a-mole: new files in data/ never
# show up as untracked.
data/*
!data/.gitkeep

# Vite/vitest crash artifacts and local agent settings
vitest.config.js.timestamp-*.mjs
.claude/settings.local.json

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Database files
*.db
*.db-shm
*.db-wal

# Personal/financial files — must never be committed
IanOsrin_*.xlsx
IanOsrin_*.docx
Possible\ FX.docx

# Working notes — keep out of the repo
SESSION_NOTES.md

# Playwright — keep specs + committed baseline snapshots, ignore run artifacts
test-results/
playwright-report/
blob-report/
.playwright/
