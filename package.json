{
  "name": "mass-music",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node cluster.js",
    "start:single": "node server.js",
    "dev": "node --watch server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run tests/frontend",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "smoke": "node scripts/smoke.js",
    "db:migrate": "node scripts/db/migrate.mjs",
    "sync:catalog": "node scripts/sync/catalog-sync.mjs",
    "build:suggest": "node scripts/semantic/build-suggest.mjs",
    "refresh:suggest": "node scripts/semantic/build-index.mjs && node scripts/semantic/build-suggest.mjs && node scripts/semantic/enrich-artwork.mjs && aws s3 cp data/suggest.db s3://mass-music-audio-files/suggest/album-index.db --content-type application/x-sqlite3 && echo '[refresh] uploaded \u2014 live app will hot-swap within SUGGEST_REFRESH_MINUTES'",
    "load-test": "cd scripts && npx artillery run load-test.yml",
    "load-test:smoke": "cd scripts && bash run-load-test.sh --smoke",
    "load-test:full": "cd scripts && bash run-load-test.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:peek": "node scripts/db/peek.mjs",
    "refresh:index": "node scripts/semantic/refresh-index.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^12.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "lru-cache": "^11.2.2",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0",
    "sqlite-vec": "^0.1.9",
    "undici": "^7"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IanOsrin/MASS.git"
  },
  "bugs": {
    "url": "https://github.com/IanOsrin/MASS/issues"
  },
  "homepage": "https://github.com/IanOsrin/MASS#readme",
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "artillery": "^2.0.30",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
