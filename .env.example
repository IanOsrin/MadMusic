# FileMaker connection
FM_HOST=https://yourhost.fmcloud.fm
FM_DB=YourDatabase
FM_USER=youruser
FM_PASS=yourpassword

FM_LAYOUT=API_Album_Songs
FM_TOKENS_LAYOUT=API_Access_Tokens
FM_STREAM_EVENTS_LAYOUT=API_Stream_Events
FM_MP3_FIELD=mp3
FM_AUDIO_FIELD=Audio File
FM_TIMEZONE_OFFSET=+2

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
AUTH_SECRET=replace_with_strong_random_secret

# Kafka (optional)
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=mass-api
KAFKA_TOPIC_PLAY=streams.play-events.v1

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# Paystack
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_SUBSCRIPTION_PLAN_CODE=PLN_...
PAYSTACK_SUBSCRIPTION_DISPLAY=R20/Week

# Admin
ADMIN_SECRET=replace_with_strong_random_secret

# Security / hardening
# Absolute public base URL — share, payment-callback and activation links are
# built from this. Without it they fall back to the (spoofable) Host header.
APP_URL=https://yourdomain.com
# Number of proxy hops in front of the app (Render = 1). NEVER "true" in prod.
TRUST_PROXY=1
# Audio Lab unlock key. REQUIRED — no hardcoded fallback. Unset => feature 503s.
AUDIO_LAB_KEY=replace_with_strong_random_secret
# Telkom integration master switch. OFF by default (ring-fenced June 2026 while
# waiting on deliverables from Telkom). All /api/telkom/* return 404 until true.
# Before enabling, fix the open Telkom findings listed in server.js.
# TELKOM_ENABLED=true
# Telkom webhook shared secret. Unset => webhooks unauthenticated (warns in logs).
# Coordinate value + header name (default x-telkom-secret) with Telkom.
TELKOM_WEBHOOK_SECRET=
# Optional header name Telkom sends the secret in (default: x-telkom-secret).
# TELKOM_WEBHOOK_HEADER=x-telkom-secret
# Max days a Telkom webhook may grant a token (default 366).
# TELKOM_MAX_TOKEN_DAYS=366
# Hours a paid download/ringtone link stays valid after purchase (default 48).
# DOWNLOAD_LINK_TTL_HOURS=48
# Max saved songs/albums per user library (default 5000).
# LIBRARY_MAX_ITEMS=5000
# Require an admin key to publish a playlist to the public catalogue (default off).
# PUBLISH_REQUIRES_ADMIN=true

# FileMaker layouts
FM_DOWNLOADS_LAYOUT=API_Download_Purchases

# ── Postgres metadata mirror (read replica of MadStreamer / fmcloud) ──────────
# One-way mirror: FileMaker stays the system of record; Postgres only serves
# catalog READS when METADATA_SOURCE=postgres. See docs/postgres-mirror.md.
# Render injects DATABASE_URL automatically for its managed Postgres. Leave
# UNSET to run entirely on FileMaker (local + main default).
DATABASE_URL=
# SSL: 'no-verify' (Render external URLs), 'true' (verify chain), 'false' (off).
# Default: off for localhost, no-verify otherwise.
# DATABASE_SSL=no-verify
# Pool sizing (defaults: max 10, idle 30s, connect 10s).
# PG_POOL_MAX=10
# Which backend serves catalog READS: filemaker (default) | postgres.
# Flip to postgres ONLY in the live env, AFTER `npm run db:migrate` + first sync.
# METADATA_SOURCE=filemaker

# FileMaker Archive (separate WAV vault)
FM_ARCHIVE_HOST=
FM_ARCHIVE_DB=
FM_ARCHIVE_USER=
FM_ARCHIVE_PASS=
FM_ARCHIVE_LAYOUT=
FM_ARCHIVE_WAV_FIELD=

# S3 (for audio delivery)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_BASE_URL=

# Job queue
REDIS_URL=redis://localhost:6379
USE_IN_PROCESS_QUEUE=true

# Ingest admin (ingest subsystem removed — leave blank; do not set a weak value)
# INGEST_ADMIN_SECRET=
# INGEST_INVITE_TOKEN=

# Performance
# Pre-warm catalogue SWR caches (featured, new-releases, singles, g100, trending,
# genres) on boot so the first visitor after a deploy/restart doesn't pay the
# cold-FileMaker cost. Only worker 0 pre-warms. Recommended in production.
# PREWARM_CACHES=true
# Per-token /my-stats cache window in ms (default 300000 = 5 min).
# MY_STATS_CACHE_TTL_MS=300000
# Serve pre-generated WebP artwork derivatives (see scripts/artwork-resize).
# Set to true ONLY after that batch has finished uploading artwork/resized/*.
# Rail endpoints then return _300.webp URLs instead of 3000px masters. Off = masters.
# ARTWORK_THUMBS=true

# Optional
# FM_VISIBILITY_FIELD=Visibility
# FM_VISIBILITY_VALUE=show
# DEBUG_STREAM_EVENTS=true
# CORS_ORIGIN=https://yourdomain.com
# HTTP2_ENABLED=true
# HTTP2_CERT_PATH=/path/to/cert.pem
# HTTP2_KEY_PATH=/path/to/key.pem
