# FileMaker connection
FM_HOST=https://yourhost.fmcloud.fm
FM_DB=YourDatabase
FM_USER=youruser
FM_PASS=yourpassword

FM_LAYOUT=API_Album_Songs
FM_TOKENS_LAYOUT=API_Access_Tokens
FM_STREAM_EVENTS_LAYOUT=API_Stream_Events
FM_MP3_FIELD=mp3
FM_AUDIO_FIELD=Audio File
FM_TIMEZONE_OFFSET=+2

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
AUTH_SECRET=replace_with_strong_random_secret

# Kafka (optional)
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=mass-api
KAFKA_TOPIC_PLAY=streams.play-events.v1

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# Paystack
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_SUBSCRIPTION_PLAN_CODE=PLN_...
PAYSTACK_SUBSCRIPTION_DISPLAY=R20/Week

# Admin
ADMIN_SECRET=replace_with_strong_random_secret

# FileMaker layouts
FM_DOWNLOADS_LAYOUT=API_Download_Purchases

# Optional
# FM_VISIBILITY_FIELD=Visibility
# FM_VISIBILITY_VALUE=show
# DEBUG_STREAM_EVENTS=true
# TRUST_PROXY=true
# CORS_ORIGIN=https://yourdomain.com
# HTTP2_ENABLED=true
# HTTP2_CERT_PATH=/path/to/cert.pem
# HTTP2_KEY_PATH=/path/to/key.pem
